# GPU Inference Observatory — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# Or run:  make setup   (interactive wizard writes .env automatically)
#
# NEVER commit .env — it contains your API key.

# ── Backend selection ────────────────────────────────────────────
# nim-hosted   → calls integrate.api.nvidia.com  (free, no GPU needed)
# nim-container → runs NIM Docker container on your GPU
BACKEND=nim-hosted

# ── NVIDIA API key (required for both backends) ──────────────────
# Get a free key at: https://build.nvidia.com
# Keys start with "nvapi-"
NVIDIA_API_KEY=nvapi-your-key-here

# ── Model ────────────────────────────────────────────────────────
# NIM model ID — must match a model available on your tier.
# See: https://build.nvidia.com/models
NIM_MODEL=meta/llama-3.1-8b-instruct

# ── NIM hosted API base URL (nim-hosted only) ────────────────────
NIM_BASE=https://integrate.api.nvidia.com/v1

# ── NIM container settings (nim-container only) ──────────────────
# NGC_API_KEY is used to pull the container image from nvcr.io.
# Usually the same value as NVIDIA_API_KEY.
# NGC_API_KEY=nvapi-your-key-here

# Full nvcr.io image path — written by the setup wizard automatically.
# NIM_IMAGE=nvcr.io/nim/meta/llama-3.1-8b-instruct:latest

# Available VRAM on your GPU in GB.
# GPU_VRAM_GB=24

# Host/port where the NIM container is listening.
# NIM_HOST=localhost
# NIM_PORT=8000
