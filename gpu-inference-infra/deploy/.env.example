# GPU Inference Infrastructure — Environment Variables
# Copy this to .env and fill in your values:  cp .env.example .env

# HuggingFace token (required to download gated models like Llama 3)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Model to serve
MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# GPU memory utilization (0.0 to 1.0)
GPU_MEM_UTIL=0.85

# Max sequence length (prompt + output tokens)
MAX_MODEL_LEN=4096

# Max concurrent batched requests
MAX_NUM_SEQS=8
